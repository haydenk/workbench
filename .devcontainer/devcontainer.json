{
  "name": "workbench",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // ─── Features ──────────────────────────────────────────────────────────────
  // Universal image already ships: git, gh, kubectl, helm, azure-cli, docker CLI,
  // python, node, go, ruby, java, .net. Only add what's missing.
  "features": {
    // Set zsh as default shell + fish
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": false,
      "upgradePackages": false
    },
    // git-lfs not in universal
    "ghcr.io/devcontainers/features/git-lfs:1": {},

    // Docker socket wiring (CLI is in universal, but socket setup is not)
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false,
      "dockerDashComposeVersion": "latest"
    },

  },

  // ─── Lifecycle scripts ──────────────────────────────────────────────────────
  "postCreateCommand": "bash /workspaces/remote-work/.devcontainer/scripts/post-create.sh",
  "postStartCommand": "bash /workspaces/remote-work/.devcontainer/scripts/post-start.sh",

  // ─── VS Code / Cursor settings ──────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        // Shell
        "mads-hartmann.bash-ide-vscode",
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        // Git
        "eamodio.gitlens",
        "mhutchie.git-graph",
        // General
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-docker",
        "EditorConfig.EditorConfig",
        "usernamehw.errorlens",
        "zhuangtongfa.material-theme",
        "pkief.material-icon-theme",
        // AI
        "anthropic.claude-vscode",
        "github.copilot"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.fontSize": 14,
        "editor.fontFamily": "'Fira Code', 'Cascadia Code', monospace",
        "editor.fontLigatures": true,
        "editor.fontSize": 14,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "git.autofetch": true,
        "gitlens.hovers.currentLine.over": "line"
      }
    }
  },

  "hostRequirements": {
    "cpus": 8,
    "memory": "32gb",
    "storage": "64gb"
  },

  "postAttachCommand": "echo '✓ remote-work ready'"
}
