{
  "name": "workbench",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  // ─── Features ──────────────────────────────────────────────────────────────
  "features": {
    // Set zsh as default shell + configure common utils
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": false,
      "upgradePackages": false
    },
    // gh CLI
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // git-lfs
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    // Docker socket wiring
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": true,
      "dockerDashComposeVersion": "latest"
    }
  },

  // ─── Lifecycle scripts ──────────────────────────────────────────────────────
  "postCreateCommand": "bash /workspaces/workbench/.devcontainer/scripts/post-create.sh",
  "postStartCommand": "bash /workspaces/workbench/.devcontainer/scripts/post-start.sh",

  // ─── VS Code / Cursor settings ──────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        // Shell
        "mads-hartmann.bash-ide-vscode",
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        // Git
        "eamodio.gitlens",
        "mhutchie.git-graph",
        // General
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-docker",
        "EditorConfig.EditorConfig",
        "usernamehw.errorlens",
        "zhuangtongfa.material-theme",
        "pkief.material-icon-theme",
        // AI
        "anthropic.claude-vscode",
        "github.copilot"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.fontSize": 14,
        "editor.fontFamily": "'Fira Code', 'Cascadia Code', monospace",
        "editor.fontLigatures": true,
        "editor.fontSize": 14,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "git.autofetch": true,
        "gitlens.hovers.currentLine.over": "line"
      }
    }
  },

  "hostRequirements": {
    "cpus": 8,
    "memory": "32gb",
    "storage": "64gb"
  },

  "postAttachCommand": "echo '✓ workbench ready'"
}
