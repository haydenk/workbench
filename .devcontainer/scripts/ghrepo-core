#!/usr/bin/env sh
# ghrepo-core — shell-agnostic plumbing for ghrepo.{zsh,fish}.
#
# Subcommands:
#   fetch [org]              Print TSV of repos accessible via $GH_TOKEN.
#                            Honors $GHREPO_LIMIT (default 1000) and warns on
#                            stderr when the result count hits the cap.
#                            Columns: nameWithOwner, lock-emoji, description,
#                                     updatedAt(YYYY-MM-DD)
#   clone <owner/repo> <dir> Partial-clone owner/repo into dir,
#                            or fast-forward-pull if dir/.git already exists.
#
# Caller sets GH_TOKEN to the right PAT before invoking. Indirect-expansion
# of GH_TOKEN_ORG_<NAME> stays in the per-shell wrappers because the syntax
# differs (zsh ${(P)var} vs fish `env | string replace`).

set -eu

cmd_fetch() {
  limit="${GHREPO_LIMIT:-1000}"
  src="${1:-personal}"
  # Capture gh output (stderr merged) so we can distinguish "fetch failed" from
  # "fetch succeeded with zero results" — silently treating both as "no repos"
  # was the old footgun on auth failures.
  if [ -n "${1:-}" ]; then
    raw=$(gh repo list "$1" --limit "$limit" \
      --json nameWithOwner,description,isPrivate,isArchived,updatedAt 2>&1) || {
      echo "ghrepo-core: gh repo list failed for $src — check 'gh auth status':" >&2
      echo "$raw" >&2
      return 1
    }
  else
    raw=$(gh repo list --limit "$limit" \
      --json nameWithOwner,description,isPrivate,isArchived,updatedAt 2>&1) || {
      echo "ghrepo-core: gh repo list failed for $src — check 'gh auth status':" >&2
      echo "$raw" >&2
      return 1
    }
  fi
  printf '%s' "$raw" | jq -r '.[] | [
      .nameWithOwner,
      (if .isPrivate then "🔒" else "🌐" end),
      (if .isArchived then "[archived] " else "" end) + (.description // ""),
      (.updatedAt | split("T")[0])
    ] | @tsv' \
  | awk -v lim="$limit" -v src="$src" '
      { print; count++ }
      END {
        if (count >= lim) {
          printf "ghrepo-core: %s results may be truncated at %d; raise via --limit\n", src, lim > "/dev/stderr"
        }
      }
    '
}

cmd_clone() {
  selected="${1:?ghrepo-core clone: missing <owner/repo>}"
  target="${2:?ghrepo-core clone: missing <target-dir>}"
  if [ -d "$target/.git" ]; then
    echo "Already cloned → $target (pulling)"
    git -C "$target" pull --ff-only 2>/dev/null || true
  else
    echo "Cloning $selected → $target"
    mkdir -p "$(dirname "$target")"
    gh repo clone "$selected" "$target" -- --filter=blob:none
  fi
}

case "${1:-}" in
  fetch) shift; cmd_fetch "$@" ;;
  clone) shift; cmd_clone "$@" ;;
  *) echo "ghrepo-core: usage: ghrepo-core {fetch [org]|clone <owner/repo> <dir>}" >&2; exit 1 ;;
esac
